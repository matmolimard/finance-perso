# Configuration OpenRouter pour le système de conseil IA
# Copiez ce fichier vers .env et remplissez vos valeurs
# 
# Commande: cp env.example .env
# Puis éditez .env avec vos valeurs

# Clé API OpenRouter (obligatoire)
# Obtenez votre clé sur https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-votre-cle-ici

# Modèle à utiliser (optionnel, défaut: anthropic/claude-3.5-sonnet)
# Options disponibles:
# - anthropic/claude-3.5-sonnet (recommandé)
# - openai/gpt-4o
# - openai/gpt-4-turbo
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Identifiants SwissLife pour le scraper assureur
# Le scraper accepte aussi SWISSLIFE_USERNAME / SWISSLIFE_PASSWORD
SWISSLIFE_LOGIN=votre-identifiant-swisslife
SWISSLIFE_PASSWORD=votre-mot-de-passe-swisslife

# Identifiants Himalia / Generali pour le scraper assureur
HIMALIA_LOGIN=votre-identifiant-himalia
HIMALIA_PASSWORD=votre-mot-de-passe-himalia

# Clé Anti-Captcha (obligatoire pour Himalia headless)
# Obtenez votre clé sur https://anti-captcha.com/
ANTICAPTCHA_KEY=votre-cle-anticaptcha



